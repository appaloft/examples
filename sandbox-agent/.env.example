APPALOFT_API_URL=https://app.example.com/api
APPALOFT_SESSION_COOKIE=better-auth.session_token=replace-me
APPALOFT_SANDBOX_TEMPLATE_ID=sbt_replace_me
APPALOFT_PI_HARNESS_TEMPLATE_ID=aht_pi_managed_v1

# Chat-to-app
APP_PROMPT=Build a small task tracker in /workspace/app

# Approval loop
APPALOFT_RUN_ID=srun_replace_me
# Leave unset to inspect pending approvals without resolving one.
# APPALOFT_APPROVAL_ID=saa_replace_me
# APPALOFT_APPROVAL_DECISION=approve

# Preview and promote
APPALOFT_SANDBOX_ID=sbx_replace_me
APPALOFT_SOURCE_ROOT=app
APPALOFT_PROJECT_ID=prj_replace_me
APPALOFT_ENVIRONMENT_ID=env_replace_me
APPALOFT_RESOURCE_NAME=Generated app
# Leave false to stop after creating a promotion plan.
APPALOFT_ACCEPT_PROMOTION=false
